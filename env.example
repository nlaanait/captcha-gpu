# Lambda Cloud API Key
# Get your API key from: https://cloud.lambdalabs.com/api-keys
LAMBDA_CLOUD_API_KEY=your_api_key_here

# Your public IP for firewall rules (optional, used for SSH/TCP restriction)
# You can find it with: curl ifconfig.me
MY_PUBLIC_IP=

# Specific SSH Key name to use for automatic launches
# If left empty, the tool will attempt to use the first available SSH key
LAMBDA_SSH_KEY=

# Prefix for automatically launched instances
LAMBDA_INSTANCE_PREFIX=lambda-captcha
